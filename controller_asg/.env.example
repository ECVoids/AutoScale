# ══════════════════════════════════════════════════════════
#  ControllerASG — Variables de entorno
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA subas el .env con credenciales al repositorio.
# ══════════════════════════════════════════════════════════

# ── Escalamiento ──────────────────────────────────────────
MIN_INSTANCES=2
MAX_INSTANCES=5
EVAL_INTERVAL=30        # segundos entre evaluaciones de política
COOLDOWN_UP=120         # segundos de cooldown tras un scale-up
COOLDOWN_DOWN=180       # segundos de cooldown tras un scale-down

# ── AWS ───────────────────────────────────────────────────
AWS_REGION=us-east-1
INSTANCE_TYPE=t2.micro
KEY_NAME=vockey

# IDs de red — completar con los valores de tu VPC en AWS Academy
SECURITY_GROUP_ID=sg-XXXXXXXXXXXXXXXXX
SUBNET_ID=subnet-XXXXXXXXXXXXXXXXX

# AMI personalizada generada por create_ami.sh
# Si se define aquí tiene precedencia sobre config_ami.txt
AMI_ID=

# Perfil IAM para la instancia (dejar vacío si no aplica)
IAM_INSTANCE_PROFILE=

# ── MonitorS (compartido) ─────────────────────────────────
# IP privada de la instancia donde corre el MonitorS
MONITOR_S_HOST=10.0.0.X
MONITOR_S_PORT=50052

# Puerto HTTP de la AppInstance (inyectado via user-data)
APP_PORT=8080

# ── Logging ───────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
