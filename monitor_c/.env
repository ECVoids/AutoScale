# ── Identidad de esta instancia ──────────────────────────────────────────────
# En producción (EC2) estos valores se inyectan desde user-data o el ControllerASG.
# Localmente usamos valores de ejemplo para desarrollo/pruebas.

INSTANCE_ID=instance-local-01
INSTANCE_IP=127.0.0.1

# ── Puerto donde escucha este servidor gRPC ───────────────────────────────────
MONITOR_C_PORT=50051

# ── Ubicación del MonitorS para auto-registro ─────────────────────────────────
# En docker-compose se usa el nombre del servicio como hostname.
# En EC2 se reemplaza por la IP privada o DNS del MonitorS.
MONITOR_S_HOST=monitor-s
MONITOR_S_PORT=50052

# ── Metadatos del agente ──────────────────────────────────────────────────────
AGENT_VERSION=1.0.0

# ── Intervalo de actualización de métricas (segundos) ────────────────────────
METRICS_INTERVAL=5
