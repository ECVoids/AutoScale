# monitor-s/.env
# ── Identidad ─────────────────────────────────────────────────────────────────
MONITOR_S_ID=monitor-s-1

# ── gRPC ──────────────────────────────────────────────────────────────────────
# Puerto donde MonitorS escucha registros de los MonitorC
MONITOR_S_PORT=50052

# ── Polling ───────────────────────────────────────────────────────────────────
# Segundos entre rondas completas de Ping + GetMetrics a todas las instancias
POLL_INTERVAL=10

# Timeout por llamada gRPC hacia cada MonitorC (segundos)
HEARTBEAT_TIMEOUT=5

# ── Límites ───────────────────────────────────────────────────────────────────
# Máximo de instancias que MonitorS acepta registrar
# (debe coincidir con maxInstances del ControllerASG)
MAX_INSTANCES=5
