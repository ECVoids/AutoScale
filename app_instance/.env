# app-instance/.env
# Copiar como .env y ajustar antes de correr localmente o en EC2.
# En producción estas variables se inyectan via user-data o docker-compose.

# ── Identidad ────────────────────────────────────────────────────────────────
# ID único de la instancia. En EC2 se sobreescribe automáticamente con el
# Instance ID real (ver scripts/startup.sh).
INSTANCE_ID=local-dev

# ── HTTP ──────────────────────────────────────────────────────────────────────
APP_PORT=8080

# ── Simulación de carga ───────────────────────────────────────────────────────
# Intervalo entre ticks de simulación (segundos)
LOAD_TICK_SECONDS=2.0

# Media de la carga hacia la que deriva el sistema (0-100)
LOAD_MEAN=50.0

# Fuerza de reversión a la media (Ornstein-Uhlenbeck). Rango sugerido: 0.01 - 0.15
LOAD_REVERSION=0.05

# Desviación estándar del ruido gaussiano por tick
LOAD_NOISE_STD=3.0

# Probabilidad de que ocurra un pico en cada tick (0.0 - 1.0)
LOAD_SPIKE_PROB=0.03

# Rango de magnitud de cada pico (puntos porcentuales)
LOAD_SPIKE_MIN=20.0
LOAD_SPIKE_MAX=40.0

# Cuánto decae el efecto de un pico por tick (0.0 = instantáneo, 1.0 = permanente)
LOAD_SPIKE_DECAY=0.8
